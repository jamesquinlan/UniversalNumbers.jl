    given-names: James
    orcid: "https://orcid.org/0000-0002-2628-1651"
    affiliation: "University of Southern Maine"
  - family-names: Arciero
    given-names: Mike
    orcid: "https://orcid.org/0009-0000-9107-6171"
    affiliation: "University of Southern Maine"
repository-code: "https://github.com/jamesquinlan/UniversalNumbers.jl"
url: "https://github.com/jamesquinlan/UniversalNumbers.jl"
license: MIT
version: 0.1.0
date-released: "2026-06-29"
keywords:
  - Julia
  - computer arithmetic
  - posit
  - takum
  - floating-point
  - number systems
  - reproducibility
